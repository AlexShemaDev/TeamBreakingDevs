---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Oswald:wght@300;400;600;700&family=Special+Elite&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --yellow: #f5c518;
    --green: #3d9970;
    --dark-green: #1a4a2e;
    --black: #0a0a0a;
    --off-white: #e8e0c8;
    --rust: #8b3a0f;
    --meth-blue: #a8d8ea;
    --smoke: rgba(200, 220, 200, 0.08);
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background-color: var(--black);
    color: var(--off-white);
    font-family: 'Oswald', sans-serif;
    overflow-x: hidden;
  }
</style>
